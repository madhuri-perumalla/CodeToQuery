# ============================================
# CodeToQuery Backend Environment Configuration
# ============================================
# IMPORTANT: Copy this file to .env and fill in all required values
# DO NOT commit .env file to version control
# ============================================

# Application
APP_NAME=CodeToQuery
APP_ENV=development
APP_VERSION=0.1.0
DEBUG=true
API_V1_PREFIX=/api/v1

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=1

# ============================================
# REQUIRED: Database Configuration
# ============================================
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Example: postgresql://myuser:securepassword@localhost:5432/codetoquery
DATABASE_URL=postgresql://CHANGE_ME:CHANGE_ME@localhost:5432/codetoquery
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=3600

# ============================================
# REQUIRED: Redis Configuration
# ============================================
# Format: redis://:PASSWORD@HOST:PORT/DB
# Example: redis://:securepassword@localhost:6379/0
REDIS_URL=redis://:CHANGE_ME@localhost:6379/0
CELERY_BROKER_URL=redis://:CHANGE_ME@localhost:6379/0
CELERY_RESULT_BACKEND=redis://:CHANGE_ME@localhost:6379/0

# ============================================
# REQUIRED: Security Configuration
# ============================================
# Generate a secure key: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Minimum 32 characters required
SECRET_KEY=CHANGE_ME_GENERATE_SECURE_KEY_MIN_32_CHARS
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Content-Type,Authorization

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Analysis
DEFAULT_COST_THRESHOLD=1000
DEFAULT_SIMILARITY_THRESHOLD=0.85
EXPLAIN_TIMEOUT=30
ENABLE_ANALYZE=false

# File Upload
MAX_UPLOAD_SIZE=10485760
ALLOWED_EXTENSIONS=.js,.py,.ts,.go,.java
